{
  "name": "@ai-kingdom/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node ../../scripts/with-test-env.mjs node --import tsx --test src/**/*.test.ts",
    "test:api": "node ../../scripts/with-test-env.mjs node --import tsx --test src/**/*.test.ts",
    "test:db:prepare": "node ../../scripts/prepare-test-db.mjs",
    "test:db:migrate": "node ../../scripts/with-test-env.mjs npx prisma migrate deploy",
    "test:db:seed": "node ../../scripts/with-test-env.mjs tsx prisma/seed.ts",
    "test:db:reset": "node ../../scripts/with-test-env.mjs npx prisma migrate reset --force",
    "db:generate": "node ../../scripts/with-root-env.mjs npx prisma generate",
    "db:migrate": "node ../../scripts/with-root-env.mjs npx prisma migrate deploy",
    "db:deploy": "node ../../scripts/with-root-env.mjs npx prisma migrate deploy",
    "db:seed": "node ../../scripts/with-root-env.mjs tsx prisma/seed.ts",
    "db:seed:staging": "node ../../scripts/with-root-env.mjs tsx prisma/seed-staging.ts",
    "data:inspect-pollution": "node ../../scripts/with-root-env.mjs tsx src/scripts/inspect-pollution.ts",
    "data:cleanup-test-data": "node ../../scripts/with-root-env.mjs tsx src/scripts/cleanup-test-data.ts",
    "data:archive-low-quality-inbox": "node ../../scripts/with-root-env.mjs tsx src/scripts/archive-low-quality-inbox.ts",
    "data:inspect-low-value": "node ../../scripts/with-root-env.mjs tsx src/scripts/inspect-low-value.ts",
    "data:archive-low-value": "node ../../scripts/with-root-env.mjs tsx src/scripts/archive-low-value.ts",
    "data:inspect-work-orders": "node ../../scripts/with-root-env.mjs tsx src/scripts/inspect-work-orders.ts",
    "data:archive-low-value-work-orders": "node ../../scripts/with-root-env.mjs tsx src/scripts/archive-low-value-work-orders.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "picomatch": "^2.3.2",
    "prisma": "^5.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/picomatch": "^4.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
