{
  "name": "@ai-kingdom/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node ../../scripts/with-root-env.mjs node --import tsx --test src/**/*.test.ts",
    "db:generate": "node ../../scripts/with-root-env.mjs prisma generate",
    "db:migrate": "node ../../scripts/with-root-env.mjs prisma migrate dev --name init",
    "db:deploy": "node ../../scripts/with-root-env.mjs prisma migrate deploy",
    "db:seed": "node ../../scripts/with-root-env.mjs tsx prisma/seed.ts",
    "db:seed:staging": "node ../../scripts/with-root-env.mjs tsx prisma/seed-staging.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "prisma": "^5.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
