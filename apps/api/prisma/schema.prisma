generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderEnvironmentMode {
  SANDBOX
  PRODUCTION
  DISABLED
}

enum KnowledgeCandidateStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
  ARCHIVED
}

enum AutomationJobStatus {
  QUEUED
  APPROVED
  CLAIMED
  RUNNING
  NEEDS_REVIEW
  COMPLETED
  FAILED
  CANCELLED
}

enum AutomationJobMode {
  OBSERVE
  PLAN_ONLY
  SANDBOX_PATCH
  VALIDATION_ONLY
  EXTERNAL_AGENT
}

enum ContextBindingStatus {
  FRESH
  STALE
  MISSING
  PARTIAL
}

enum ContextValidationStatus {
  FRESH
  STALE
  MISSING
  PARTIAL
  NOT_REQUIRED
}

enum AgentRunnerStatus {
  ONLINE
  OFFLINE
  ERROR
}

enum KnowledgeCategory {
  PROJECT_FACT
  ARCHITECTURE_DECISION
  USER_PREFERENCE
  PROVIDER_BEHAVIOR
  WORKFLOW_RULE
  BUG_LEARNING
  PROMPT_PATTERN
  COST_LEARNING
  RISK
  UNKNOWN
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum TaskMode {
  ASK
  PLAN
  RESEARCH
  BUILD
}

enum CouncilSessionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum MemoryType {
  DECISION
  FACT
  PREFERENCE
  CONSTRAINT
  PROJECT_NOTE
  LESSON
}

enum MemoryImportance {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportCategory {
  STRATEGY
  RESEARCH
  ARCHITECTURE
  FINANCE
  GENERAL
  OTHER
}

enum ReportImportance {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SettingsCategory {
  AI
  UI
  SECURITY
  SYSTEM
}

enum UserRole {
  KING
  CROWN_PRINCE
  MINISTER
  SCRIBE
}

enum LedgerType {
  COST
  CREDIT
  ADJUSTMENT
}

enum NoticeSeverity {
  INFO
  WARNING
  CRITICAL
}

enum NoticeStatus {
  UNREAD
  READ
  ARCHIVED
}

enum MatterStatus {
  DETECTED
  INVESTIGATING
  COUNCIL_REVIEW
  AWAITING_ROYAL_DECISION
  APPROVED
  REJECTED
  EXECUTING
  COMPLETED
}

enum MatterPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MatterCategory {
  TREASURY
  SECURITY
  REVENUE
  SYSTEM
  RESEARCH
  PRODUCT
  GENERAL
}

enum ExternalAgentType {
  CLAUDE_CODE
  CODEX
  CLINE
  KILO
  ANTIGRAVITY
  HERMES
  OPENCODE
  CURSOR
  DEVIN
  GENERIC_CLI
  MANUAL_ONLY
  CUSTOM
}

enum ExternalAgentRunStatus {
  QUEUED
  RUNNING
  WAITING
  SUCCEEDED
  FAILED
  TIMED_OUT
  CANCELLED
  NEEDS_REVIEW
}

enum WorkOrderExecutionTarget {
  AUTO
  INTERNAL_AGENT
  RUNNER_VALIDATION
  RUNNER_PATCH
  EXTERNAL_AGENT
}

enum KingdomNextExecutableAction {
  NONE
  CREATE_WORK_ORDER
  CREATE_EXTERNAL_HANDOFF
  RUN_VALIDATION
  SCAN_LOCAL_DOCS
  BIND_CONTEXT
  REVIEW_PATCH
}

enum ExternalAgentExecutionMode {
  MANUAL_COPY_PASTE
  CLI_MANUAL
  API
  FUTURE_AUTOMATED
}

enum ExternalAgentSafetyLevel {
  LOW_RISK
  MEDIUM_RISK
  HIGH_RISK
}

enum WorkOrderStatus {
  DRAFT
  READY
  IN_PROGRESS
  NEEDS_REVIEW
  COMPLETED
  FAILED
  CANCELLED
  ARCHIVED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkSessionStatus {
  STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
  INTERRUPTED
}

enum ImplementationTestResult {
  NOT_RUN
  PASSED
  FAILED
  PARTIAL
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectRoutingStatus {
  SUGGESTED
  CONFIRMED
  REJECTED
  NEEDS_REVIEW
}

enum ProjectInboxStatus {
  PENDING
  ASSIGNED
  DISMISSED
  ARCHIVED
}

enum ArtifactType {
  PROMPT
  SPEC
  DECISION
  IMPLEMENTATION_REPORT
  HANDOFF_BRIEF
  ARCHITECTURE_NOTE
  MARKET_RESEARCH
  CODE_PLAN
  ROYAL_DECREE
  GENERAL_NOTE
}

enum LivingLoopStatus {
  STARTED
  COMPLETED
  FAILED
  SKIPPED
}

enum LivingLoopTriggerType {
  MANUAL
  SCHEDULED
}

enum AutomationCandidateKind {
  WORK_ORDER_REVIEW
  VALIDATION_JOB
  PATCH_REVIEW
  MEMORY_REVIEW
  CLEANUP_REVIEW
  PROVIDER_REVIEW
  PROJECT_REVIEW
  RUNNER_REVIEW
  SANDBOX_PATCH
}

enum AutomationCandidatePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AutomationCandidateRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AutomationCandidateStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
  ARCHIVED
}

enum RoyalBriefStatus {
  DRAFT
  READY
  ARCHIVED
}

enum RoyalBriefGeneratedBy {
  SYSTEM
  KING
}

enum DirectAgentSessionStatus {
  OPEN
  COMPLETED
  FAILED
  ARCHIVED
}

enum DirectAgentMessageRole {
  USER
  AGENT
  SYSTEM
}

enum DirectAgentRequestType {
  GENERAL_QUESTION
  RESEARCH_ASSIGNMENT
  SUMMARY_ASSIGNMENT
  PERSONAL_TASK
}

enum KingdomObjectiveStatus {
  ACTIVE
  PAUSED
  ACHIEVED
  ARCHIVED
}

enum SuccessMetricDirection {
  INCREASE
  DECREASE
  MAINTAIN
}

enum SuccessMetricStatus {
  UNKNOWN
  ON_TRACK
  AT_RISK
  OFF_TRACK
  ACHIEVED
}

enum KingdomAssetType {
  PRODUCT
  TEMPLATE
  SERVICE
  KNOWLEDGE
  AUTOMATION
  CONTENT
  COMMUNITY
  OTHER
}

enum KingdomAssetStatus {
  IDEA
  BUILDING
  ACTIVE
  MONETIZING
  PAUSED
  ARCHIVED
}

enum RevenueStreamStatus {
  PLANNED
  TESTING
  ACTIVE
  PAUSED
  ENDED
}

enum RevenueModel {
  SUBSCRIPTION
  ONE_TIME
  SERVICE
  AFFILIATE
  ADS
  LICENSING
  OTHER
}

enum OpportunityStatus {
  INBOX
  REVIEWING
  VALIDATING
  APPROVED
  REJECTED
  ARCHIVED
}

enum OpportunityExperimentStatus {
  PLANNED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model Notice {
  id               String         @id @default(cuid())
  projectId        String?
  title            String
  content          String
  severity         NoticeSeverity @default(INFO)
  status           NoticeStatus   @default(UNREAD)
  sourceType       String?
  sourceId         String?
  createdByAgentId String?
  isTestData       Boolean        @default(false)
  testRunId        String?
  dataSource       String?
  dataQuality      String?
  provenance       Json?
  traceId          String?
  createdBySystem  Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model Matter {
  id               String         @id @default(cuid())
  projectId        String?
  title            String
  description      String
  status           MatterStatus   @default(DETECTED)
  priority         MatterPriority @default(MEDIUM)
  category         MatterCategory @default(GENERAL)
  sourceType       String?
  sourceId         String?
  assignedAgentId  String?
  isTestData       Boolean        @default(false)
  testRunId        String?
  dataSource       String?
  dataQuality      String?
  provenance       Json?
  traceId          String?
  createdBySystem  Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  displayName   String         @map("name")
  role          UserRole       @default(KING)
  isActive      Boolean        @default(true)
  isTestData    Boolean        @default(false)
  testRunId     String?
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tasks         Task[]
  reports       Report[]
  memories      Memory[]
  aiUsageTraces AIUsageTrace[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  workOrders    WorkOrder[]
  ownedProjects Project[]
  createdAutomationJobs  AutomationJob[] @relation("AutomationJobCreatedBy")
  approvedAutomationJobs AutomationJob[] @relation("AutomationJobApprovedBy")
  reviewedPatchArtifacts PatchArtifact[] @relation("PatchArtifactReviewedBy")
  royalBriefs            RoyalBrief[]    @relation("RoyalBriefGeneratedByUser")
  directAgentSessions    DirectAgentSession[]
  strategyObjectives     KingdomObjective[]
  opportunities          KingdomOpportunity[]
  opportunityExperiments OpportunityExperiment[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Agent {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  title       String
  role        String
  specialty   String
  prompt      String
  description String       @default("")
  systemPrompt String       @default("")
  skills      String[]      @default([])
  responseStyle String      @default("")
  isActive    Boolean         @default(true)
  isTestData  Boolean         @default(false)
  testRunId   String?
  priority    Int             @default(100)
  preferredProviderId String?
  defaultModel String?
  fallbackProviderIds String[] @default([])
  fallbackModels      String[] @default([])
  routingPolicy       String?  @default("GLOBAL_ROUTING")
  costPreference String?
  temperature Float?
  maxTokens   Int?
  parameterMode    String?  @default("ROLE_DEFAULT")
  modelParameters  Json?
  config       Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  responses    AgentResponse[]
  usageRecords UsageRecord[]
  activities   AgentActivity[]
  aiUsageTraces AIUsageTrace[]
  aiUsageTraceSteps AIUsageTraceStep[]
  assignedWorkOrders WorkOrder[]
  automationJobs     AutomationJob[] @relation("AgentAutomationJobs")
  reviewSummaries    AgentReviewSummary[] @relation("AgentReviewSummaries")
  directSessions      DirectAgentSession[]
  directMessages      DirectAgentMessage[]
}

model ExternalAgent {
  id                    String                     @id @default(cuid())
  name                  String
  type                  ExternalAgentType
  roleTitle             String
  description           String                     @default("")
  capabilities          String[]                   @default([])
  executionMode         ExternalAgentExecutionMode @default(MANUAL_COPY_PASTE)
  command               String?
  workingDirectory      String?
  environmentProfile    String?
  isActive              Boolean                    @default(true)
  bridgeEnabled         Boolean                    @default(false)
  maxRuntimeSeconds     Int                        @default(900)
  requiresApproval      Boolean                    @default(true)
  safetyLevel           ExternalAgentSafetyLevel   @default(MEDIUM_RISK)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  workOrders            WorkOrder[]
  workSessions          WorkSession[]
  implementationReports ImplementationReport[]
  externalAgentRuns     ExternalAgentRun[]
}

model Project {
  id                String          @id @default(cuid())
  name              String          @unique
  codename          String?
  description       String          @default("")
  status            ProjectStatus   @default(ACTIVE)
  priority          ProjectPriority @default(MEDIUM)
  goals             String[]        @default([])
  keywords          String[]        @default([])
  aliases           String[]        @default([])
  repositoryUrl     String?
  localPath         String?
  activeMilestone   String?
  ownerUserId       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  owner             User?           @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  tasks             Task[]
  matters           Matter[]
  notices           Notice[]
  councilSessions   CouncilSession[]
  reports           Report[]
  memories          Memory[]
  usageRecords      UsageRecord[]
  agentActivities   AgentActivity[]
  aiUsageTraces      AIUsageTrace[]
  aiUsageTraceSteps  AIUsageTraceStep[]
  workOrders        WorkOrder[]
  implementationReports ImplementationReport[]
  handoffBriefs     HandoffBrief[]
  artifacts         Artifact[]
  automationJobs    AutomationJob[]
  routingCandidates ProjectRoutingCandidate[]
  repositorySnapshots RepositorySnapshot[]
  patchArtifacts      PatchArtifact[]
  localDocumentRoots     LocalDocumentRoot[]
  localDocumentSnapshots LocalDocumentSnapshot[]
  localDocumentInsights  LocalDocumentInsight[]
  reviewSummaries        AgentReviewSummary[]
  directAgentSessions    DirectAgentSession[]
  strategyObjectives     KingdomObjective[]
  successMetrics         SuccessMetric[]
  kingdomAssets          KingdomAsset[]
  revenueStreams         RevenueStream[]
  opportunities          KingdomOpportunity[]
}

model DirectAgentSession {
  id                   String                   @id @default(cuid())
  agentId              String
  projectId            String?
  createdByUserId      String
  title                String
  requestType          DirectAgentRequestType   @default(GENERAL_QUESTION)
  status               DirectAgentSessionStatus @default(OPEN)
  summary              String?
  latestTraceId        String?
  latestUsageRecordId  String?
  artifactId           String?
  knowledgeCandidateId String?
  providerName         String?
  modelUsed            String?
  fallbackNotice       String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  completedAt          DateTime?
  agent                Agent                    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  project              Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdByUser        User                     @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  messages             DirectAgentMessage[]

  @@index([agentId])
  @@index([projectId])
  @@index([createdByUserId])
  @@index([requestType])
  @@index([status])
  @@index([createdAt])
}

model DirectAgentMessage {
  id            String                 @id @default(cuid())
  sessionId     String
  agentId       String?
  role          DirectAgentMessageRole
  content       String
  traceId       String?
  usageRecordId String?
  metadata      Json?
  createdAt     DateTime               @default(now())
  session       DirectAgentSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agent         Agent?                  @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([agentId])
  @@index([role])
  @@index([traceId])
  @@index([createdAt])
}

model KingdomObjective {
  id              String                 @id @default(cuid())
  projectId       String?
  createdByUserId String?
  title           String
  description     String                 @default("")
  status          KingdomObjectiveStatus @default(ACTIVE)
  priority        ProjectPriority        @default(MEDIUM)
  targetDate      DateTime?
  sourceType      String?
  sourceId        String?
  tags            String[]               @default([])
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  project         Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdByUser   User?                  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  metrics         SuccessMetric[]
  opportunities   KingdomOpportunity[]

  @@index([projectId])
  @@index([createdByUserId])
  @@index([status])
  @@index([priority])
  @@index([targetDate])
}

model SuccessMetric {
  id            String                 @id @default(cuid())
  objectiveId   String?
  projectId     String?
  name          String
  description   String                 @default("")
  unit          String                 @default("")
  direction     SuccessMetricDirection @default(INCREASE)
  baselineValue Float?
  currentValue  Float                  @default(0)
  targetValue   Float?
  status        SuccessMetricStatus    @default(UNKNOWN)
  sourceType    String?
  sourceId      String?
  lastMeasuredAt DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  objective     KingdomObjective?      @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  project       Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([objectiveId])
  @@index([projectId])
  @@index([status])
  @@index([lastMeasuredAt])
}

model KingdomAsset {
  id                     String             @id @default(cuid())
  projectId              String?
  name                   String
  type                   KingdomAssetType   @default(OTHER)
  status                 KingdomAssetStatus @default(IDEA)
  description            String             @default("")
  valueHypothesis        String             @default("")
  targetCustomer         String             @default("")
  monthlyRevenueEstimate Float              @default(0)
  monthlyCostEstimate    Float              @default(0)
  sourceType             String?
  sourceId               String?
  tags                   String[]           @default([])
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  project                Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  revenueStreams         RevenueStream[]
  opportunities          KingdomOpportunity[]

  @@index([projectId])
  @@index([type])
  @@index([status])
  @@index([monthlyRevenueEstimate])
}

model RevenueStream {
  id             String              @id @default(cuid())
  projectId      String?
  assetId        String?
  name           String
  model          RevenueModel        @default(OTHER)
  status         RevenueStreamStatus @default(PLANNED)
  currency       String              @default("USD")
  monthlyRevenue Float               @default(0)
  monthlyCost    Float               @default(0)
  confidence     Float?
  notes          String              @default("")
  sourceType     String?
  sourceId       String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  project        Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  asset          KingdomAsset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([assetId])
  @@index([status])
  @@index([model])
}

model KingdomOpportunity {
  id                       String            @id @default(cuid())
  projectId                String?
  objectiveId              String?
  assetId                  String?
  createdByUserId          String?
  title                    String
  problem                  String            @default("")
  proposedValue            String            @default("")
  targetCustomer           String            @default("")
  status                   OpportunityStatus @default(INBOX)
  priority                 ProjectPriority   @default(MEDIUM)
  confidence               Float?
  score                    Int               @default(0)
  estimatedMonthlyRevenue  Float             @default(0)
  estimatedEffort          String            @default("")
  riskLevel                MatterPriority    @default(MEDIUM)
  nextAction               String            @default("")
  sourceType               String?
  sourceId                 String?
  traceId                  String?
  tags                     String[]          @default([])
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  reviewedAt               DateTime?
  project                  Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  objective                KingdomObjective? @relation(fields: [objectiveId], references: [id], onDelete: SetNull)
  asset                    KingdomAsset?     @relation(fields: [assetId], references: [id], onDelete: SetNull)
  createdByUser            User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  experiments              OpportunityExperiment[]

  @@index([projectId])
  @@index([objectiveId])
  @@index([assetId])
  @@index([createdByUserId])
  @@index([status])
  @@index([priority])
  @@index([score])
  @@index([traceId])
}

model OpportunityExperiment {
  id               String                      @id @default(cuid())
  opportunityId    String
  createdByUserId  String?
  title            String
  hypothesis       String                      @default("")
  validationMethod String                      @default("")
  successCriteria  String                      @default("")
  status           OpportunityExperimentStatus @default(PLANNED)
  resultSummary    String?
  resultMetric     Float?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  opportunity      KingdomOpportunity          @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  createdByUser    User?                       @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([opportunityId])
  @@index([createdByUserId])
  @@index([status])
  @@index([completedAt])
}

model RepositorySnapshot {
  id             String   @id @default(cuid())
  projectId      String
  generatedAt    DateTime @default(now())
  repositoryUrl  String?
  branch         String?
  framework      String?
  language       String?
  packageManager String?
  prismaModels   Json     @default("[]")
  modules        Json     @default("[]")
  services       Json     @default("[]")
  controllers    Json     @default("[]")
  apiRoutes      Json     @default("[]")
  frontendPages  Json     @default("[]")
  summary        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectRoutingCandidate {
  id                 String               @id @default(cuid())
  sourceType         String
  sourceId           String
  suggestedProjectId String?
  confidenceScore    Int
  reason             String
  status             ProjectRoutingStatus @default(SUGGESTED)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  suggestedProject   Project?             @relation(fields: [suggestedProjectId], references: [id], onDelete: SetNull)
}

model ProjectInboxItem {
  id                  String             @id @default(cuid())
  sourceType          String
  sourceId            String
  title               String
  summary             String
  candidateProjectIds String[]           @default([])
  status              ProjectInboxStatus @default(PENDING)
  assignedProjectId   String?
  confidenceScore     Int?
  reason              String?
  // M15F routing quality gate fields
  routingConfidence   Int?
  routingQuality      String?            // HIGH, MEDIUM, LOW, DEBUG_ONLY, NO_MATCH
  dataQualityLabel    String?            // TRUSTED_SOURCE, REVIEW_REQUIRED, LEGACY, TEST, UNKNOWN_SOURCE
  humanTitle          String?
  humanReason         String?
  evidence            Json?
  ignoredSignals      Json?
  isTestData          Boolean            @default(false)
  testRunId           String?
  dataSource          String?
  dataQuality         String?
  provenance          Json?
  traceId             String?
  createdBySystem     Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model Artifact {
  id         String       @id @default(cuid())
  projectId  String?
  title      String
  type       ArtifactType @default(GENERAL_NOTE)
  content    String
  sourceType String?
  sourceId   String?
  tags       String[]     @default([])
  isTestData Boolean      @default(false)
  testRunId  String?
  dataSource String?
  dataQuality String?
  provenance Json?
  traceId    String?
  createdBySystem Boolean @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  project    Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model WorkOrder {
  id                      String                 @id @default(cuid())
  projectId               String?
  title                   String
  objective               String
  context                 String                 @default("")
  instructions            String                 @default("")
  constraints             String                 @default("")
  acceptanceCriteria      String[]               @default([])
  validationCommands      String[]               @default([])
  targetProject           String?
  targetRepository        String?
  sourceType              String?
  sourceId                String?
  assignedExternalAgentId String?
  assignedAgentId         String?
  assignedAgentReason     String?
  assignedAgentConfidence Float?
  executionTarget         WorkOrderExecutionTarget @default(AUTO)
  autoRetryCount          Int                      @default(0)
  maxAutoRetries          Int                      @default(2)
  lastExternalAgentRunId  String?
  blockedReason           String?
  status                  WorkOrderStatus        @default(DRAFT)
  priority                WorkOrderPriority      @default(MEDIUM)
  createdByUserId         String?
  createdByAgentId        String?
