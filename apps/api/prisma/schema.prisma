generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProviderEnvironmentMode {
  SANDBOX
  PRODUCTION
  DISABLED
}

enum KnowledgeCandidateStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
  ARCHIVED
}

enum KnowledgeCategory {
  PROJECT_FACT
  ARCHITECTURE_DECISION
  USER_PREFERENCE
  PROVIDER_BEHAVIOR
  WORKFLOW_RULE
  BUG_LEARNING
  PROMPT_PATTERN
  COST_LEARNING
  RISK
  UNKNOWN
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum TaskMode {
  ASK
  PLAN
  RESEARCH
  BUILD
}

enum CouncilSessionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum MemoryType {
  DECISION
  FACT
  PREFERENCE
  CONSTRAINT
  PROJECT_NOTE
  LESSON
}

enum MemoryImportance {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportCategory {
  STRATEGY
  RESEARCH
  ARCHITECTURE
  FINANCE
  GENERAL
  OTHER
}

enum ReportImportance {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SettingsCategory {
  AI
  UI
  SECURITY
  SYSTEM
}

enum UserRole {
  KING
  CROWN_PRINCE
  MINISTER
  SCRIBE
}

enum LedgerType {
  COST
  CREDIT
  ADJUSTMENT
}

enum NoticeSeverity {
  INFO
  WARNING
  CRITICAL
}

enum NoticeStatus {
  UNREAD
  READ
  ARCHIVED
}

enum MatterStatus {
  DETECTED
  INVESTIGATING
  COUNCIL_REVIEW
  AWAITING_ROYAL_DECISION
  APPROVED
  REJECTED
  EXECUTING
  COMPLETED
}

enum MatterPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MatterCategory {
  TREASURY
  SECURITY
  REVENUE
  SYSTEM
  RESEARCH
  PRODUCT
  GENERAL
}

enum ExternalAgentType {
  CLAUDE_CODE
  CODEX
  CLINE
  KILO
  ANTIGRAVITY
  HERMES
  OPENCODE
  CUSTOM
}

enum ExternalAgentExecutionMode {
  MANUAL_COPY_PASTE
  CLI_MANUAL
  API
  FUTURE_AUTOMATED
}

enum ExternalAgentSafetyLevel {
  LOW_RISK
  MEDIUM_RISK
  HIGH_RISK
}

enum WorkOrderStatus {
  DRAFT
  READY
  IN_PROGRESS
  NEEDS_REVIEW
  COMPLETED
  FAILED
  CANCELLED
  ARCHIVED
}

enum WorkOrderPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkSessionStatus {
  STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
  INTERRUPTED
}

enum ImplementationTestResult {
  NOT_RUN
  PASSED
  FAILED
  PARTIAL
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectRoutingStatus {
  SUGGESTED
  CONFIRMED
  REJECTED
  NEEDS_REVIEW
}

enum ProjectInboxStatus {
  PENDING
  ASSIGNED
  DISMISSED
  ARCHIVED
}

enum ArtifactType {
  PROMPT
  SPEC
  DECISION
  IMPLEMENTATION_REPORT
  HANDOFF_BRIEF
  ARCHITECTURE_NOTE
  MARKET_RESEARCH
  CODE_PLAN
  ROYAL_DECREE
  GENERAL_NOTE
}

model Notice {
  id               String         @id @default(cuid())
  projectId        String?
  title            String
  content          String
  severity         NoticeSeverity @default(INFO)
  status           NoticeStatus   @default(UNREAD)
  sourceType       String?
  sourceId         String?
  createdByAgentId String?
  isTestData       Boolean        @default(false)
  testRunId        String?
  dataSource       String?
  dataQuality      String?
  provenance       Json?
  traceId          String?
  createdBySystem  Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model Matter {
  id               String         @id @default(cuid())
  projectId        String?
  title            String
  description      String
  status           MatterStatus   @default(DETECTED)
  priority         MatterPriority @default(MEDIUM)
  category         MatterCategory @default(GENERAL)
  sourceType       String?
  sourceId         String?
  assignedAgentId  String?
  isTestData       Boolean        @default(false)
  testRunId        String?
  dataSource       String?
  dataQuality      String?
  provenance       Json?
  traceId          String?
  createdBySystem  Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  displayName   String         @map("name")
  role          UserRole       @default(KING)
  isActive      Boolean        @default(true)
  isTestData    Boolean        @default(false)
  testRunId     String?
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tasks         Task[]
  reports       Report[]
  memories      Memory[]
  aiUsageTraces AIUsageTrace[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  workOrders    WorkOrder[]
  ownedProjects Project[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Agent {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  title       String
  role        String
  specialty   String
  prompt      String
  description String       @default("")
  systemPrompt String       @default("")
  skills      String[]      @default([])
  responseStyle String      @default("")
  isActive    Boolean         @default(true)
  isTestData  Boolean         @default(false)
  testRunId   String?
  priority    Int             @default(100)
  preferredProviderId String?
  defaultModel String?
  fallbackProviderIds String[] @default([])
  costPreference String?
  temperature Float?
  maxTokens   Int?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  responses    AgentResponse[]
  usageRecords UsageRecord[]
  activities   AgentActivity[]
  aiUsageTraces AIUsageTrace[]
  aiUsageTraceSteps AIUsageTraceStep[]
}

model ExternalAgent {
  id                    String                     @id @default(cuid())
  name                  String
  type                  ExternalAgentType
  roleTitle             String
  description           String                     @default("")
  capabilities          String[]                   @default([])
  executionMode         ExternalAgentExecutionMode @default(MANUAL_COPY_PASTE)
  isActive              Boolean                    @default(true)
  safetyLevel           ExternalAgentSafetyLevel   @default(MEDIUM_RISK)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  workOrders            WorkOrder[]
  workSessions          WorkSession[]
  implementationReports ImplementationReport[]
}

model Project {
  id                String          @id @default(cuid())
  name              String          @unique
  codename          String?
  description       String          @default("")
  status            ProjectStatus   @default(ACTIVE)
  priority          ProjectPriority @default(MEDIUM)
  goals             String[]        @default([])
  keywords          String[]        @default([])
  aliases           String[]        @default([])
  repositoryUrl     String?
  localPath         String?
  activeMilestone   String?
  ownerUserId       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  owner             User?           @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  tasks             Task[]
  matters           Matter[]
  notices           Notice[]
  councilSessions   CouncilSession[]
  reports           Report[]
  memories          Memory[]
  usageRecords      UsageRecord[]
  agentActivities   AgentActivity[]
  aiUsageTraces      AIUsageTrace[]
  aiUsageTraceSteps  AIUsageTraceStep[]
  workOrders        WorkOrder[]
  implementationReports ImplementationReport[]
  handoffBriefs     HandoffBrief[]
  artifacts         Artifact[]
  routingCandidates ProjectRoutingCandidate[]
}

model ProjectRoutingCandidate {
  id                 String               @id @default(cuid())
  sourceType         String
  sourceId           String
  suggestedProjectId String?
  confidenceScore    Int
  reason             String
  status             ProjectRoutingStatus @default(SUGGESTED)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  suggestedProject   Project?             @relation(fields: [suggestedProjectId], references: [id], onDelete: SetNull)
}

model ProjectInboxItem {
  id                  String             @id @default(cuid())
  sourceType          String
  sourceId            String
  title               String
  summary             String
  candidateProjectIds String[]           @default([])
  status              ProjectInboxStatus @default(PENDING)
  assignedProjectId   String?
  confidenceScore     Int?
  reason              String?
  // M15F routing quality gate fields
  routingConfidence   Int?
  routingQuality      String?            // HIGH, MEDIUM, LOW, DEBUG_ONLY, NO_MATCH
  dataQualityLabel    String?            // TRUSTED_SOURCE, REVIEW_REQUIRED, LEGACY, TEST, UNKNOWN_SOURCE
  humanTitle          String?
  humanReason         String?
  evidence            Json?
  ignoredSignals      Json?
  isTestData          Boolean            @default(false)
  testRunId           String?
  dataSource          String?
  dataQuality         String?
  provenance          Json?
  traceId             String?
  createdBySystem     Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model Artifact {
  id         String       @id @default(cuid())
  projectId  String?
  title      String
  type       ArtifactType @default(GENERAL_NOTE)
  content    String
  sourceType String?
  sourceId   String?
  tags       String[]     @default([])
  isTestData Boolean      @default(false)
  testRunId  String?
  dataSource String?
  dataQuality String?
  provenance Json?
  traceId    String?
  createdBySystem Boolean @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  project    Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model WorkOrder {
  id                      String                 @id @default(cuid())
  projectId               String?
  title                   String
  objective               String
  context                 String                 @default("")
  instructions            String                 @default("")
  constraints             String                 @default("")
  acceptanceCriteria      String[]               @default([])
  validationCommands      String[]               @default([])
  targetProject           String?
  targetRepository        String?
  sourceType              String?
  sourceId                String?
  assignedExternalAgentId String?
  status                  WorkOrderStatus        @default(DRAFT)
  priority                WorkOrderPriority      @default(MEDIUM)
  createdByUserId         String?
  createdByAgentId        String?
  isTestData              Boolean                @default(false)
  createdBySystem         Boolean                @default(false)
  dataQuality             String?
  workQuality             String?
  archiveReason           String?
  archivedAt              DateTime?
  traceId                 String?
  provenance              Json?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  project                 Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignedExternalAgent   ExternalAgent?         @relation(fields: [assignedExternalAgentId], references: [id], onDelete: SetNull)
  createdByUser           User?                  @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  workSessions            WorkSession[]
  implementationReports   ImplementationReport[]
  handoffBriefs           HandoffBrief[]
}

model WorkSession {
  id              String            @id @default(cuid())
  workOrderId     String
  externalAgentId String?
  sessionLabel    String
  status          WorkSessionStatus @default(STARTED)
  inputPrompt     String
  outputSummary   String?
  startedAt       DateTime          @default(now())
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  workOrder       WorkOrder         @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  externalAgent   ExternalAgent?    @relation(fields: [externalAgentId], references: [id], onDelete: SetNull)
  reports         ImplementationReport[]
  handoffBriefs   HandoffBrief[]
}

model ImplementationReport {
  id                    String                   @id @default(cuid())
  projectId             String?
  workOrderId           String
  workSessionId         String?
  externalAgentId       String?
  summary               String
  filesChanged          String[]                 @default([])
  commandsRun           String[]                 @default([])
  testsRun              String[]                 @default([])
  testResult            ImplementationTestResult @default(NOT_RUN)
  errors                String[]                 @default([])
  decisionsMade         String[]                 @default([])
  remainingWork         String[]                 @default([])
  nextRecommendedAction String?
  rawOutput             String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  project               Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workOrder             WorkOrder                @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  workSession           WorkSession?             @relation(fields: [workSessionId], references: [id], onDelete: SetNull)
  externalAgent         ExternalAgent?           @relation(fields: [externalAgentId], references: [id], onDelete: SetNull)
}

model HandoffBrief {
  id                     String       @id @default(cuid())
  projectId              String?
  workOrderId            String
  fromWorkSessionId      String?
  title                  String
  currentStatus          String
  completedWork          String[]     @default([])
  decisionsMade          String[]     @default([])
  filesChanged           String[]     @default([])
  knownIssues            String[]     @default([])
  nextSteps              String[]     @default([])
  constraints            String[]     @default([])
  suggestedNextAgentType String?
  handoffPrompt          String
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  project                Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workOrder              WorkOrder    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  fromWorkSession        WorkSession? @relation(fields: [fromWorkSessionId], references: [id], onDelete: SetNull)
}

model AIProvider {
  id                    String                  @id
  name                  String
  type                  String
  baseUrl               String?
  defaultModel          String
  isActive              Boolean                 @default(true)
  priority              Int                     @default(100)
  costTier              String                  @default("MEDIUM")
  capabilities          Json
  config                Json?
  environmentMode       ProviderEnvironmentMode @default(PRODUCTION)
  maxTokensPerRequest   Int?
  maxRequestsPerDay     Int?
  maxTokensPerDay       Int?
  maxEstimatedCostPerDay Float?
  allowSensitiveContext Boolean                 @default(false)
  isFreeTier            Boolean                 @default(false)
  notes                 String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  routes                AIProviderRoute[]       @relation("PreferredProvider")
}

model AIProviderRoute {
  id                   String   @id @default(cuid())
  name                 String
  taskMode             TaskMode?
  agentId              String?
  preferredProviderId  String?
  preferredModel       String?
  fallbackProviderIds  String[] @default([])
  costMode             String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  preferredProvider    AIProvider? @relation("PreferredProvider", fields: [preferredProviderId], references: [id], onDelete: SetNull)
}

model Setting {
  id          String           @id @default(cuid())
  key         String           @unique
  value       String
  category    SettingsCategory
  description String?
  updatedAt   DateTime         @default(now()) @updatedAt
}

model Task {
  id            String          @id @default(cuid())
  projectId     String?
  createdBy     String          @map("userId")
  title         String
  command       String
  mode          TaskMode        @default(ASK)
  status        TaskStatus      @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  project       Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user          User            @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  sessions      CouncilSession[]
  reports       Report[]
  usageRecords  UsageRecord[]
  agentActivities AgentActivity[]
  aiUsageTraces AIUsageTrace[]
  aiUsageTraceSteps AIUsageTraceStep[]
}

model CouncilSession {
  id                 String               @id @default(cuid())
  taskId             String
  projectId          String?
  status             CouncilSessionStatus @default(PENDING)
  selectedAgentIds   String[]
  finalSummary       String?
  providerName       String?
  modelUsed          String?
  fallbackNotice     String?
  consultedMemoryIds String[]             @default([])
  autoSavedMemoryIds String[]             @default([])
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  project            Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task               Task                 @relation(fields: [taskId], references: [id], onDelete: Cascade)
  responses          AgentResponse[]
  reports            Report[]
  usageRecords       UsageRecord[]
  agentActivities     AgentActivity[]
  aiUsageTraces       AIUsageTrace[]
  aiUsageTraceSteps   AIUsageTraceStep[]
}

model AgentResponse {
  id        String         @id @default(cuid())
  sessionId String
  agentId   String
  role      String
  response  String
  createdAt DateTime       @default(now())
  session   CouncilSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  agent     Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AIUsageTrace {
  id               String   @id @default(cuid())
  traceId          String   @unique
  actorUserId      String?
  actorRole        String?
  triggerType      String
  triggerRoute     String?
  triggerLabel     String?
  projectId        String?
  taskId           String?
  councilSessionId String?
  agentId          String?
  sourceType       String
  sourceId         String?
  operation        String
  purpose          String
  providerId       String?
  providerType     String?
  providerName     String?
  model            String?
  status           String
  startedAt        DateTime @default(now())
  completedAt      DateTime?
  failedAt         DateTime?
  promptPreview    String?
  responsePreview  String?
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  actorUser        User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task             Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  councilSession   CouncilSession? @relation(fields: [councilSessionId], references: [id], onDelete: SetNull)
  agent            Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  usageRecords     UsageRecord[]
  agentActivities  AgentActivity[]
  steps            AIUsageTraceStep[]

  @@index([actorUserId])
  @@index([projectId])
  @@index([taskId])
  @@index([councilSessionId])
  @@index([agentId])
  @@index([sourceType])
  @@index([operation])
  @@index([startedAt])
}

model AIUsageTraceStep {
  id               String   @id @default(cuid())
  traceId          String
  parentStepId     String?
  stepType         String
  operation        String
  title            String
  detail           String?
  status           String
  sequence         Int
  agentId          String?
  providerId       String?
  providerType     String?
  providerName     String?
  model            String?
  usageRecordId    String?
  taskId           String?
  projectId        String?
  councilSessionId String?
  reportId         String?
  tokensUsed       Int?
  estimatedCostUSD Float?
  promptPreview    String?
  responsePreview  String?
  errorMessage     String?
  metadata         Json?
  startedAt        DateTime @default(now())
  endedAt          DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  trace            AIUsageTrace    @relation(fields: [traceId], references: [traceId], onDelete: Cascade)
  agent            Agent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  usageRecord      UsageRecord?    @relation(fields: [usageRecordId], references: [id], onDelete: SetNull)
  task             Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project          Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  councilSession   CouncilSession? @relation(fields: [councilSessionId], references: [id], onDelete: SetNull)
  report           Report?         @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([traceId])
  @@index([agentId])
  @@index([usageRecordId])
  @@index([councilSessionId])
  @@index([taskId])
  @@index([sequence])
}

model UsageRecord {
  id                   String          @id @default(cuid())
  traceId              String?
  attributionStatus    String          @default("LEGACY_UNATTRIBUTED")
  projectId            String?
  taskId               String?
  councilSessionId     String?
  agentId              String?
  provider             String
  providerId           String?
  model                String
  promptTokens         Int
  completionTokens     Int
  totalTokens          Int
  // Cache-aware token breakdown (null = provider did not return cache details)
  inputCacheHitTokens  Int?
  inputCacheMissTokens Int?
  estimatedCostUSD     Float
  estimatedCostLocal   Float
  currency             String          @default("USD")
  // Pricing quality metadata
  pricingSource        String?
  pricingStatus        String?
  pricingNotes         String?
  purpose              String?
  sourceType           String?
  sourceId             String?
  operation            String?
  requestLabel         String?
  promptPreview        String?
  responsePreview      String?
  metadata             Json?
  createdAt            DateTime        @default(now())
  trace                AIUsageTrace?   @relation(fields: [traceId], references: [traceId], onDelete: SetNull)
  project              Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task                 Task?           @relation(fields: [taskId], references: [id], onDelete: SetNull)
  councilSession       CouncilSession? @relation(fields: [councilSessionId], references: [id], onDelete: SetNull)
  agent                Agent?          @relation(fields: [agentId], references: [id], onDelete: SetNull)
  agentActivities      AgentActivity[]
  aiUsageTraceSteps    AIUsageTraceStep[]

  @@index([traceId])
  @@index([attributionStatus])
  @@index([projectId])
  @@index([sourceType])
  @@index([sourceId])
  @@index([purpose])
}

model AgentActivity {
  id               String   @id @default(cuid())
  traceId          String?
  attributionStatus String  @default("LEGACY_UNATTRIBUTED")
  agentId          String
  projectId        String?
  taskId           String?
  councilSessionId String?
  status           String
  activityType     String
  title            String
  detail           String?
  providerId       String?
  providerName     String?
  model            String?
  operation        String?
  sourceType       String?
  sourceId         String?
  requestLabel     String?
  usageRecordId    String?
  reportId         String?
  tokensUsed       Int      @default(0)
  estimatedCostUSD Float    @default(0)
  startedAt        DateTime @default(now())
  endedAt          DateTime?
  heartbeatAt      DateTime @default(now())
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  trace            AIUsageTrace? @relation(fields: [traceId], references: [traceId], onDelete: SetNull)
  agent            Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  project          Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task             Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  councilSession   CouncilSession? @relation(fields: [councilSessionId], references: [id], onDelete: SetNull)
  usageRecord      UsageRecord? @relation(fields: [usageRecordId], references: [id], onDelete: SetNull)
  report           Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([traceId])
  @@index([attributionStatus])
  @@index([agentId])
  @@index([projectId])
  @@index([taskId])
  @@index([councilSessionId])
  @@index([status])
  @@index([heartbeatAt])
  @@index([endedAt])
}

model TreasuryLedger {
  id          String     @id @default(cuid())
  type        LedgerType
  source      String
  description String
  amount      Float
  currency    String     @default("USD")
  createdAt   DateTime   @default(now())
}

model ProviderBalanceSnapshot {
  id              String   @id @default(cuid())
  providerType    String
  providerId      String?
  isAvailable     Boolean
  currency        String
  totalBalance    Float
  grantedBalance  Float
  toppedUpBalance Float
  raw             Json?
  fetchedAt       DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([providerType])
  @@index([providerId])
  @@index([fetchedAt])
}

model Budget {
  id           String   @id @default(cuid())
  name         String   @unique
  monthlyLimit Float?
  dailyLimit   Float?
  currency     String   @default("USD")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Report {
  id                     String           @id @default(cuid())
  projectId              String?
  title                  String
  summary                String
  content                String           @default("")
  sourceTaskId           String?          @map("taskId")
  sourceCouncilSessionId String?
  category               ReportCategory   @default(GENERAL)
  importance             ReportImportance @default(MEDIUM)
  tags                   String[]         @default([])
  createdBy              String           @map("userId")
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @default(now()) @updatedAt
  project                Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task                   Task?            @relation(fields: [sourceTaskId], references: [id], onDelete: SetNull)
  councilSession         CouncilSession?  @relation(fields: [sourceCouncilSessionId], references: [id], onDelete: SetNull)
  user                   User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  agentActivities        AgentActivity[]
  aiUsageTraceSteps      AIUsageTraceStep[]
}

model Memory {
  id                     String           @id @default(cuid())
  projectId              String?
  type                   MemoryType       @default(PROJECT_NOTE)
  title                  String
  content                String
  source                 String           @default("manual")
  sourceTaskId           String?
  sourceCouncilSessionId String?
  tags                   String[]         @default([])
  importance             MemoryImportance @default(MEDIUM)
  createdBy              String           @map("userId")
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @default(now()) @updatedAt
  project                Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user                   User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

model AIModelPricing {
  id                        String    @id @default(cuid())
  providerType              String
  model                     String
  displayName               String?
  canonicalModel            String?
  // Legacy simple pricing (used when cache-aware fields are absent)
  inputPerMillion           Float?
  outputPerMillion          Float
  // Cache-aware pricing
  inputCacheHitPerMillion   Float?
  inputCacheMissPerMillion  Float?
  currency                  String    @default("USD")
  source                    String    @default("manual")
  notes                     String?
  // Alias / deprecation metadata
  isAlias                   Boolean   @default(false)
  aliasOf                   String?
  isDeprecated              Boolean   @default(false)
  deprecationDate           DateTime?
  // Concurrency and thinking metadata (informational only — not enforced by backend)
  concurrencyLimit          Int?
  supportsThinking          Boolean   @default(false)
  defaultThinkingEnabled    Boolean   @default(false)
  supportedReasoningEfforts String[]  @default([])
  unsupportedThinkingParams String[]  @default([])
  isActive                  Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@unique([providerType, model])
  @@index([providerType])
  @@index([canonicalModel])
}

model KingdomCharter {
  id        String   @id @default(cuid())
  version   String   @default("1.0.0")
  mission   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KingdomVision {
  id        String   @id @default(cuid())
  version   String   @default("2026")
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgentKnowledgeCandidate {
  id                String                   @id @default(cuid())
  agentId           String
  projectId         String?
  taskId            String?
  councilSessionId  String?
  traceId           String?
  sourceType        String
  sourceId          String?
  title             String
  content           String
  summary           String?
  category          KnowledgeCategory        @default(UNKNOWN)
  confidence        Float?
  status            KnowledgeCandidateStatus @default(PENDING)
  proposedByAgentId String?
  reviewedByUserId  String?
  reviewedAt        DateTime?
  rejectionReason   String?
  tags              String[]                 @default([])
  fingerprint       String?
  metadata          Json?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([agentId])
  @@index([projectId])
  @@index([taskId])
  @@index([traceId])
  @@index([status])
  @@index([fingerprint])
}

model AgentKnowledgeMemory {
  id                 String    @id @default(cuid())
  sourceCandidateId  String?
  agentId            String?
  projectId          String?
  title              String
  content            String
  summary            String?
  category           KnowledgeCategory @default(UNKNOWN)
  trustLevel         String    @default("APPROVED")
  tags               String[]  @default([])
  fingerprint        String?
  createdFromTraceId String?
  approvedByUserId   String?
  approvedAt         DateTime?
  lastUsedAt         DateTime?
  useCount           Int       @default(0)
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([agentId])
  @@index([projectId])
  @@index([category])
  @@index([fingerprint])
}
