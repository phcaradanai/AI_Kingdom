}

model AgentRunner {
  id              String            @id @default(cuid())
  name            String
  description     String            @default("")
  status          AgentRunnerStatus @default(OFFLINE)
  lastHeartbeatAt DateTime?
  tokenHash       String            @unique
  version         String?
  hostname        String?
  agentCapabilities     Json?
  capabilitiesUpdatedAt DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  jobs            AutomationJob[]
}

model AutomationJob {
  id               String              @id @default(cuid())
  workOrderId      String
  projectId        String?
  agentId          String?
  runnerId         String?
  status           AutomationJobStatus @default(QUEUED)
  mode             AutomationJobMode   @default(SANDBOX_PATCH)
  commandPolicy    String?
  allowedCommands  String[]            @default([])
  provenance       Json?
  planJson         Json?
  patchSummary     String?
  logsPreview      String?
  localDocumentSnapshotId String?
  repositorySnapshotId    String?
  contextRequired         Boolean                 @default(false)
  contextValidationStatus ContextValidationStatus @default(NOT_REQUIRED)
  contextValidationSummary Json?
  importedPatch    String?
  importedPatchStatus String?
  createdByUserId  String?
  approvedByUserId String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  workOrder        WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  project          Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  agent            Agent?              @relation("AgentAutomationJobs", fields: [agentId], references: [id], onDelete: SetNull)
  runner           AgentRunner?        @relation(fields: [runnerId], references: [id], onDelete: SetNull)
  createdByUser    User?               @relation("AutomationJobCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approvedByUser   User?               @relation("AutomationJobApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  steps            AgentRunStep[]
  implementationReports ImplementationReport[]
  patchArtifacts   PatchArtifact[]
  reviewSummary    AgentReviewSummary?
  externalAgentRuns ExternalAgentRun[]

  @@index([workOrderId])
  @@index([projectId])
  @@index([agentId])
  @@index([runnerId])
  @@index([status])
  @@index([createdByUserId])
}

model AgentRunStep {
  id          String        @id @default(cuid())
  jobId       String
  sequence    Int
  stepType    String
  title       String
  detail      String?
  status      String        @default("PENDING")
  command     String?
  args        String[]      @default([])
  output      String?
  exitCode    Int?
  durationMs  Int?
  metadata    Json?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  job         AutomationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([sequence])
}

model PatchArtifact {
  id                   String    @id @default(cuid())
  automationJobId      String
  workOrderId          String
  projectId            String?
  title                String
  summary              String
  diffStat             String?
  diffPreview          String?
  fullPatch            String?
  fullPatchTruncated   Boolean   @default(false)
  filesChanged         String[]  @default([])
  riskLevel            String    @default("MEDIUM")
  validationStatus     String    @default("PENDING")
  validationResults    Json?
  reviewedByUserId     String?
  reviewNote           String?
  blockedPaths         String[]  @default([])
  branchName           String?
  branchPushed         Boolean   @default(false)
  prUrl                String?
  localDocumentSnapshotId String?
  repositorySnapshotId    String?
  baseContextStatus       ContextBindingStatus @default(MISSING)
  baseContextProvenance   Json?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  automationJob   AutomationJob @relation(fields: [automationJobId], references: [id], onDelete: Cascade)
  workOrder       WorkOrder     @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reviewedByUser  User?         @relation("PatchArtifactReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  agentReviewSummaries AgentReviewSummary[] @relation("AgentReviewPatchArtifact")

  @@index([automationJobId])
  @@index([workOrderId])
  @@index([projectId])
  @@index([riskLevel])
  @@index([validationStatus])
}

model AgentReviewSummary {
  id                  String   @id @default(cuid())
  automationJobId     String   @unique
  workOrderId         String
  projectId           String?
  reviewerAgentId     String?
  verdict             String
  confidence          String
  kingRecommendation  String
  summary             String
  whatPassed          Json     @default("[]")
  whatFailed          Json     @default("[]")
  failedCommands      Json     @default("[]")
  riskNotes           Json     @default("[]")
  nextActions         Json     @default("[]")
  externalAgentPrompt String?
  sourceReportId      String?
  patchArtifactId     String?
  rawModelOutput      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  automationJob AutomationJob @relation(fields: [automationJobId], references: [id], onDelete: Cascade)
  workOrder     WorkOrder     @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reviewerAgent Agent?        @relation("AgentReviewSummaries", fields: [reviewerAgentId], references: [id], onDelete: SetNull)
  sourceReport  ImplementationReport? @relation("AgentReviewSourceReport", fields: [sourceReportId], references: [id], onDelete: SetNull)
  patchArtifact PatchArtifact? @relation("AgentReviewPatchArtifact", fields: [patchArtifactId], references: [id], onDelete: SetNull)

  @@index([workOrderId])
  @@index([projectId])
  @@index([reviewerAgentId])
  @@index([verdict])
  @@index([kingRecommendation])
}

model LivingLoopRun {
  id                 String               @id @default(cuid())
  status             LivingLoopStatus      @default(STARTED)
  triggerType        LivingLoopTriggerType
  startedAt          DateTime             @default(now())
  completedAt        DateTime?
  summary            String?
  observedCounts     Json?
  proposedCandidates Int                  @default(0)
  skippedCandidates  Int                  @default(0)
  createdJobs        Int                  @default(0)
  skippedReasons     Json?
  error              String?
  createdAt          DateTime             @default(now())

  candidates         AutomationCandidate[]

  @@index([status])
  @@index([triggerType])
  @@index([startedAt])
}

model AutomationCandidate {
  id               String                     @id @default(cuid())
  kind             AutomationCandidateKind
  title            String
  summary          String
  reason           String
  confidence       Int
  priority         AutomationCandidatePriority @default(MEDIUM)
  riskLevel        AutomationCandidateRiskLevel @default(MEDIUM)
  sourceType       String
  sourceId         String
  projectId        String?
  agentId          String?
  workOrderId      String?
  automationJobId  String?
  patchArtifactId  String?
  proposedAction   Json
  provenance       Json
  dataQuality      String                     @default("REVIEW_REQUIRED")
  status           AutomationCandidateStatus  @default(PENDING)
  loopRunId        String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  loopRun          LivingLoopRun?             @relation(fields: [loopRunId], references: [id], onDelete: SetNull)

  @@index([kind])
  @@index([sourceType, sourceId, kind])
  @@index([status])
  @@index([confidence])
  @@index([priority])
  @@index([riskLevel])
  @@index([loopRunId])
  @@index([createdAt])
}

model RoyalBrief {
  id                 String                @id @default(cuid())
  title              String
  briefDate          DateTime
  status             RoyalBriefStatus      @default(DRAFT)
  summary            String
  highlights         Json
  decisionsNeeded    Json
  runnerStatus       Json
  livingLoopSummary  Json
  validationSummary  Json
  patchSummary       Json
  providerSummary    Json
  treasurySummary    Json
  memorySummary      Json
  riskSummary        Json
  localDocsSummary   Json                  @default("{}")
  contextHealthSummary Json                @default("{}")
  livingAgentDigest  Json
  provenance         Json
  generatedBy        RoyalBriefGeneratedBy @default(SYSTEM)
  generatedByUserId  String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  generatedByUser    User?                 @relation("RoyalBriefGeneratedByUser", fields: [generatedByUserId], references: [id], onDelete: SetNull)

  @@index([briefDate])
  @@index([status])
}

enum LocalDocumentScanStatus {
  READY
  FAILED
  PARTIAL
  STALE
}

enum LocalDocumentRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model LocalDocumentRoot {
  id             String    @id @default(cuid())
  projectId      String
  name           String
  rootPath       String
  rootPathHash   String
  isActive       Boolean   @default(true)
  allowedGlobs   Json
  blockedGlobs   Json
  maxFileBytes   Int       @default(200000)
  maxTotalBytes  Int       @default(5000000)
  lastScannedAt  DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project   Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  snapshots LocalDocumentSnapshot[]

  @@index([projectId])
  @@index([isActive])
}

model LocalDocumentSnapshot {
  id                  String                   @id @default(cuid())
  projectId           String
  localDocumentRootId String
  scanStatus          LocalDocumentScanStatus  @default(READY)
  scannedAt           DateTime                 @default(now())
  fileCount           Int
  totalBytes          Int
  summary             String
  importantFiles      Json
  detectedStack       Json?
  packageScripts      Json?
  riskZones           Json?
  provenance          Json
  createdAt           DateTime                 @default(now())

  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  root      LocalDocumentRoot @relation(fields: [localDocumentRootId], references: [id], onDelete: Cascade)
  insights  LocalDocumentInsight[]

  @@index([projectId])
  @@index([localDocumentRootId])
  @@index([scannedAt])
}

model LocalDocumentInsight {
  id           String                 @id @default(cuid())
  snapshotId   String
  projectId    String
  relativePath String
  fileType     String
  sizeBytes    Int
  modifiedAt   DateTime
  contentHash  String
  summary      String?
  tags         String[]              @default([])
  riskLevel    LocalDocumentRiskLevel @default(LOW)
  isDoc        Boolean                @default(false)
  isCode       Boolean                @default(false)
  isConfig     Boolean                @default(false)
  isBlocked    Boolean                @default(false)
  provenance   Json
  createdAt    DateTime               @default(now())

  snapshot LocalDocumentSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  project  Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([projectId])
  @@index([relativePath])
  @@index([riskLevel])
}
