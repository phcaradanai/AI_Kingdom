NODE_ENV=production
PORT=4000

POSTGRES_DB=ai_kingdom
POSTGRES_USER=ai_kingdom
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://ai_kingdom:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/ai_kingdom?schema=public

JWT_SECRET=
APP_PUBLIC_URL=https://ai-kingdom.example.com
CORS_ALLOWED_ORIGINS=https://ai-kingdom.example.com

AI_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=20000
AI_MAX_TOKENS=700

VITE_API_BASE_URL=https://api.ai-kingdom.example.com/api
