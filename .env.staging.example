NODE_ENV=production
PORT=4000

POSTGRES_DB=ai_kingdom
POSTGRES_USER=ai_kingdom
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://ai_kingdom:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/ai_kingdom?schema=public

JWT_SECRET=
APP_PUBLIC_URL=https://ai-kingdom.example.com
CORS_ALLOWED_ORIGINS=https://ai-kingdom.example.com

AI_PROVIDER=mock
AI_COST_MODE=balanced
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=AI Kingdom
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LOCAL_AI_BASE_URL=
LOCAL_AI_MODEL=llama3.1
AI_TIMEOUT_MS=20000
AI_MAX_TOKENS=700

VITE_API_BASE_URL=https://api.ai-kingdom.example.com/api
