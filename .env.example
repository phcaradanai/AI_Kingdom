DATABASE_URL="postgresql://kingdom:kingdom@localhost:5432/ai_kingdom?schema=public"
JWT_SECRET="change-me-in-production"
PORT=4000
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"
APP_PUBLIC_URL="http://localhost:5173"
AI_PROVIDER="mock"
AI_COST_MODE="balanced"
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_COMPATIBLE_BASE_URL=""
OPENAI_COMPATIBLE_API_KEY=""
OPENAI_COMPATIBLE_MODEL="gpt-4o-mini"
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_HTTP_REFERER=""
OPENROUTER_X_TITLE="AI Kingdom"
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-1.5-flash"
LOCAL_AI_BASE_URL=""
LOCAL_AI_MODEL="llama3.1"
AI_TIMEOUT_MS=20000
AI_MAX_TOKENS=700
# Kingdom Autonomy Scheduler (M19): interval (ms) the background worker drives the
# Living Loop. Gated by LIVING_LOOP_ENABLED setting; min enforced is 15000.
LIVING_LOOP_INTERVAL_MS=300000
VITE_API_URL="http://localhost:4000/api"
VITE_API_BASE_URL="http://localhost:4000/api"

# Single shared timeout (ms) for every runner child process command
# (npm ci, db:generate, typecheck, workspace tests, build).
RUNNER_COMMAND_TIMEOUT_MS=600000

# ── Agent CLI execution (runner) ─────────────────────────────────────────────
# Let the runner drive an external agent CLI (Claude Code, Codex, etc.) headlessly
# inside the isolated job workspace so it can make REAL edits. The resulting diff is
# captured as a SANDBOX_PATCH artifact for King review — the runner still never
# pushes/merges/deploys. Disabled unless explicitly enabled, and each agent type must
# be configured by name.
#   - {PROMPT} in *_ARGS is replaced with the work order prompt; if absent, the prompt
#     is piped to the CLI's stdin.
#   - *_ARGS accepts a JSON array (["-p","{PROMPT}"]) or a space-separated string.
#   - Optional AGENT_CLI_<TYPE>_TIMEOUT_MS overrides RUNNER_COMMAND_TIMEOUT_MS.
# AGENT_CLI_ENABLED=true
# AGENT_CLI_CLAUDE_CODE_COMMAND=claude
# AGENT_CLI_CLAUDE_CODE_ARGS=["-p","{PROMPT}"]
# AGENT_CLI_CODEX_COMMAND=codex
# AGENT_CLI_CODEX_ARGS=exec
# AGENT_CLI_CODEX_TIMEOUT_MS=900000
