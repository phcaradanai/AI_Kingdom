{
  "name": "ai-kingdom",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @ai-kingdom/api & npm run dev --workspace @ai-kingdom/web",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspace @ai-kingdom/api",
    "db:generate": "npm run db:generate --workspace @ai-kingdom/api",
    "db:migrate": "npm run db:migrate --workspace @ai-kingdom/api",
    "db:deploy": "npm run db:deploy --workspace @ai-kingdom/api",
    "db:seed": "npm run db:seed --workspace @ai-kingdom/api",
    "db:seed:staging": "npm run db:seed:staging --workspace @ai-kingdom/api"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
